---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Reveal from '../components/Reveal.astro';
import PullQuote from '../components/PullQuote.astro';
import { site } from '../data/site.ts';
import { about } from '../data/about.ts';
import PortraitCarousel from '../components/PortraitCarousel.astro';

// Resolve featured-work slugs into project entries (cover/hook stay in sync with Work)
const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const bySlug = new Map(allProjects.map((p) => [p.id, p]));
const featured = about.featuredWork
  .map((slug) => bySlug.get(slug))
  .filter((p): p is (typeof allProjects)[number] => Boolean(p));

const atAGlance = [
  { label: 'based in',   value: site.city },
  { label: 'school',     value: site.school },
  { label: 'studying',   value: site.major },
  { label: 'off-screen', value: 'photography · table tennis · Go' },
];
---

<Base
  title={`About — ${site.name}`}
  description={`${site.name} — ${site.major} applicant in ${site.city}. AI research, software that solves real problems, and photography on the side.`}
>
  <div class="container about">

    <!-- 1. Header: intro + at-a-glance + portrait -->
    <Reveal>
      <header class="about__header">
        <div class="about__intro">
          <span class="about__kicker">about</span>
          <h1 class="about__title">Hi, I'm Jayden.</h1>
          <p class="about__intro-text">{about.intro}</p>
          <dl class="about__glance">
            {atAGlance.map((g) => (
              <div class="about__glance-cell">
                <dt class="about__glance-label">{g.label}</dt>
                <dd class="about__glance-value">{g.value}</dd>
              </div>
            ))}
          </dl>
        </div>
        <div class="about__portrait">
          <PortraitCarousel />
        </div>
      </header>
    </Reveal>

    <!-- 2. Theme pull-quote -->
    <Reveal>
      <PullQuote quote={about.theme} />
    </Reveal>

    <!-- 3 & 4. Featured-work read-throughs -->
    {featured.map((p, i) => {
      const coverIsSvg = p.data.cover.format === 'svg';
      const label = i === 0 ? 'research' : "the one I'm proudest of";
      const alt = p.data.coverCaption ?? p.data.title;
      return (
        <Reveal>
          <a class="about__feature" href={`/work/${p.id}`}>
            <div class="about__feature-thumb-wrap">
              {coverIsSvg ? (
                <img src={p.data.cover.src} alt={alt} class="about__feature-thumb" loading="lazy" />
              ) : (
                <Image src={p.data.cover} alt={alt} class="about__feature-thumb" widths={[200, 400]} sizes="160px" loading="lazy" />
              )}
            </div>
            <div class="about__feature-body">
              <span class="about__feature-label">{label}</span>
              <h2 class="about__feature-title">{p.data.title}</h2>
              <p class="about__feature-summary">{p.data.hook}</p>
              <span class="about__feature-link">read the full case study →</span>
            </div>
          </a>
        </Reveal>
      );
    })}

    <!-- 5. Honors -->
    <Reveal>
      <section class="about__section" aria-labelledby="honors-heading">
        <h2 class="about__section-label" id="honors-heading">honors</h2>
        <ul class="about__honors" role="list">
          {about.honors.map((h) => (
            <li class="about__honor">
              <span class="about__honor-name">{h.name}</span>
              {h.note && <span class="about__honor-note"> — {h.note}</span>}
            </li>
          ))}
        </ul>
      </section>
    </Reveal>

    <!-- 6. Beyond the screen -->
    <Reveal>
      <section class="about__section" aria-labelledby="beyond-heading">
        <h2 class="about__section-label" id="beyond-heading">beyond the screen</h2>
        <ul class="about__beyond" role="list">
          {about.beyond.map((b) => (
            <li class="about__beyond-item">
              <div class="about__beyond-thumb" aria-hidden="true">
                <span>// TODO</span>
              </div>
              <div class="about__beyond-meta">
                <span class="about__beyond-label">{b.label}</span>
                {b.note && <span class="about__beyond-note">{b.note}</span>}
              </div>
            </li>
          ))}
        </ul>
        <p class="about__beyond-close">Precision and patience, on and off the screen.</p>
      </section>
    </Reveal>

    <!-- 7. Contact + résumé -->
    <Reveal>
      <section class="about__section" aria-labelledby="contact-heading">
        <h2 class="about__section-label" id="contact-heading">contact</h2>
        <div class="about__contact-row">
          {site.email.includes('@') ? (
            <a href={`mailto:${site.email}`} class="about__contact-link">{site.email}</a>
          ) : (
            <span class="about__contact-todo">{site.email} — coming soon</span>
          )}
          <a href="/resume.pdf" class="about__resume-btn" download="Jayden_W_Resume.pdf">
            résumé PDF ↓
          </a>
        </div>
        {/* TODO: drop a real resume.pdf into /public */}
      </section>
    </Reveal>

  </div>
</Base>

<style>
  .about {
    padding-block: clamp(3rem, 6vw, 5rem) var(--section-gap);
  }

  /* Header */
  .about__header {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--space-12);
    align-items: start;
    margin-bottom: var(--space-12);
  }

  .about__kicker {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    color: var(--accent);
    margin-bottom: var(--space-4);
  }

  .about__title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 460;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: var(--space-5);
  }

  .about__intro-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--ink);
    max-width: 56ch;
    margin-bottom: var(--space-6);
  }

  .about__glance {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .about__glance-cell {
    padding: var(--space-4) var(--space-4);
    border-left: 1px solid var(--rule);
    min-width: 0;
  }

  .about__glance-cell:first-child {
    border-left: none;
    padding-left: 0;
  }

  .about__glance-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.03em;
    color: var(--accent);
    margin-bottom: var(--space-2);
  }

  .about__glance-value {
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--ink);
  }

  .about__portrait {
    position: sticky;
    top: calc(4rem + var(--space-8));
  }

  .about__portrait-img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 2px;
    display: block;
  }

  .about__portrait-caption {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    opacity: 0.8;
    margin-top: var(--space-2);
  }

  /* Featured-work read-through */
  .about__feature {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-6);
    align-items: center;
    padding-block: var(--space-8);
    border-top: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
  }

  .about__feature:last-of-type {
    border-bottom: 1px solid var(--rule);
  }

  .about__feature-thumb-wrap {
    width: 160px;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 2px;
  }

  .about__feature-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .about__feature:hover .about__feature-thumb {
    transform: scale(1.03);
  }

  .about__feature-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: var(--accent);
    display: block;
    margin-bottom: var(--space-2);
  }

  .about__feature-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 460;
    line-height: 1.2;
    color: var(--ink);
    margin-bottom: var(--space-2);
  }

  .about__feature-summary {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-2);
    margin-bottom: var(--space-3);
    max-width: 56ch;
  }

  .about__feature-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
  }

  /* Sections */
  .about__section {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--rule);
  }

  .about__section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--ink-2);
    margin-bottom: var(--space-6);
  }

  /* Honors — one restrained line, not a trophy wall */
  .about__honors {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
  }

  .about__honor-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 460;
    color: var(--ink);
  }

  .about__honor-note {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-2);
  }

  /* Beyond */
  .about__beyond {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  .about__beyond-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .about__beyond-thumb {
    aspect-ratio: 1 / 1;
    border: 1px dashed var(--accent);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    opacity: 0.7;
  }

  .about__beyond-label {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 460;
    color: var(--ink);
  }

  .about__beyond-note {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--ink-2);
    line-height: 1.4;
  }

  .about__beyond-close {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--ink-2);
    margin-top: var(--space-8);
  }

  /* Contact */
  .about__contact-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .about__contact-link,
  .about__contact-todo {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--accent);
    text-decoration: none;
  }

  .about__contact-todo {
    opacity: 0.8;
  }

  .about__resume-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    padding: var(--space-3) var(--space-6);
    border-radius: 2px;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .about__resume-btn:hover {
    background: var(--accent);
    color: var(--bg);
  }

  .about__resume-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .about__feature-thumb,
    .about__resume-btn { transition: none; }
  }

  @media (max-width: 900px) {
    .about__header {
      grid-template-columns: 1fr;
    }
    .about__portrait {
      position: static;
      max-width: 420px;
    }
  }

  @media (max-width: 640px) {
    .about__glance {
      grid-template-columns: 1fr 1fr;
    }
    .about__glance-cell,
    .about__glance-cell:first-child {
      border-left: 1px solid var(--rule);
      padding: var(--space-3);
    }
    .about__glance-cell:first-child {
      border-left: none;
    }
    .about__feature {
      grid-template-columns: 110px 1fr;
      gap: var(--space-4);
    }
    .about__feature-thumb-wrap {
      width: 110px;
    }
    .about__beyond {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
