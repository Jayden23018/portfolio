---
import { site } from '../data/site';

const year = new Date().getFullYear();

// Only render socials that actually have a URL (instagram/bilibili are TODO).
const socials = [
  { href: site.social.github,    label: 'GitHub' },
  { href: site.social.instagram, label: 'Instagram' },
  { href: site.social.bilibili,  label: 'Bilibili' },
].filter((s) => Boolean(s.href));

---

<footer class="footer" id="contact">
  <div class="container footer__inner">
    <div class="footer__left">
      <a href={`mailto:${site.email.school}`} class="footer__email">{site.email.school}</a>
      <ul class="footer__socials" role="list">
        {socials.map(({ href, label }) => (
          <li>
            <a href={href} class="footer__social-link" target="_blank" rel="noopener noreferrer">
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <p class="footer__copy">
      © {year} {site.name} — built with Astro.
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--ink);
    margin-top: var(--section-gap);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-block: var(--space-8);
  }

  .footer__left {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .footer__email,
  .footer__social-link,
  .footer__copy {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    color: var(--ink-2);
    text-decoration: none;
  }

  .footer__email--todo {
    color: var(--accent);
    opacity: 0.8;
  }

  .footer__email:hover,
  .footer__social-link:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .footer__socials {
    list-style: none;
    padding: 0;
    display: flex;
    gap: var(--space-4);
  }
</style>
