---
// Editorial pull quote. Display serif, italic, left accent rule.
// Use via `quote` prop or as a wrapper with slot content.
interface Props {
  quote?: string;
}
const { quote } = Astro.props;
---

<blockquote class="pullquote">
  <slot>{quote}</slot>
</blockquote>

<style>
  .pullquote {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.1vw, 1.5rem);
    font-weight: 440;
    font-style: italic;
    line-height: 1.35;
    color: var(--ink);
    border-left: 3px solid var(--accent);
    padding: var(--space-1) 0 var(--space-1) var(--space-5);
    margin: var(--space-10) 0;
    max-width: 32ch;
  }
</style>
