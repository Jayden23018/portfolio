---
// PortraitCarousel — auto-playing portrait carousel for the About header.
// Transition: a cream curtain wipes down (cover), the active slide swaps under
// it, then the curtain continues down and away (reveal) — with a gentle Ken
// Burns zoom per hold.
//
// Animation is driven by CSS @keyframes (not GSAP) so there is no JS state
// machine to desync: JS only toggles the active slide and retriggers the
// curtain animation. Portraits live in src/assets/portraits/.
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import ph1 from '../assets/portraits/Weixin Image_20260616194133_47_5.jpg';
import ph2 from '../assets/portraits/Weixin Image_20260616194817_49_5.jpg';
import ph3 from '../assets/portraits/Weixin Image_20260616194910_50_5.jpg';
import ph4 from '../assets/portraits/Weixin Image_20260616195257_52_5.jpg';
import ph5 from '../assets/portraits/Weixin Image_20260616195627_53_5.jpg';
import ph6 from '../assets/portraits/Weixin Image_20260616205015_54_5.jpg';
import ph7 from '../assets/portraits/Weixin Image_20260616205017_56_5.jpg';
import ph8 from '../assets/portraits/Weixin Image_20260616205018_57_5.jpg';

interface Portrait {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

// Playback order (user-curated): original photos 5, 6, 1, 3, 8, 7, 4, 2.
const portraits: Portrait[] = [
  { src: ph5, alt: 'Portrait of Jayden (1)' },
  { src: ph6, alt: 'Portrait of Jayden (2)' },
  { src: ph1, alt: 'Portrait of Jayden (3)' },
  { src: ph3, alt: 'Portrait of Jayden (4)' },
  { src: ph8, alt: 'Portrait of Jayden (5)' },
  { src: ph7, alt: 'Portrait of Jayden (6)' },
  { src: ph4, alt: 'Portrait of Jayden (7)' },
  { src: ph2, alt: 'Portrait of Jayden (8)' },
];

const DW = 840;
const optimized: string[] = await Promise.all(
  portraits.map(async (p) => {
    if (p.src.format === 'svg') return p.src.src;
    const out = await getImage({ src: p.src, width: DW, format: 'webp' });
    return out.src;
  })
);
---

<figure class="pc" data-portrait-carousel aria-label="Portrait gallery">
  <div class="pc__viewport">
    {portraits.map((p, i) => (
      <div
        class:list={['pc__slide', { 'is-active': i === 0 }]}
        data-slide={i}
        data-alt={p.alt}
        aria-hidden={i === 0 ? 'false' : 'true'}
      >
        <img
          class="pc__img"
          src={optimized[i]}
          alt={i === 0 ? p.alt : ''}
          width="400"
          height="500"
          loading="eager"
          fetchpriority={i === 0 ? 'high' : 'low'}
          decoding="async"
        />
      </div>
    ))}
    <div class="pc__curtain" aria-hidden="true"></div>
    <nav class="pc__dots" aria-label="Choose portrait">
      {portraits.map((p, i) => (
        <button
          type="button"
          class:list={['pc__dot', { 'is-current': i === 0 }]}
          data-index={i}
          data-caption={p.caption ?? ''}
          aria-label={`Portrait ${i + 1}`}
          aria-current={i === 0 ? 'true' : 'false'}
        ></button>
      ))}
    </nav>
  </div>
  <figcaption class="pc__caption" data-caption-text>{portraits[0].caption}</figcaption>
</figure>

<script>
  const HOLD = 4;     // seconds each photo is held visible
  const WIPE_MS = 900; // total curtain animation (cover + reveal)

  document.querySelectorAll<HTMLElement>('[data-portrait-carousel]').forEach((root) => {
    const w = root as HTMLElement & { __pcInit?: boolean };
    if (w.__pcInit) return; // HMR guard
    w.__pcInit = true;

    const slides = Array.from(root.querySelectorAll<HTMLElement>('.pc__slide'));
    const curtain = root.querySelector<HTMLElement>('.pc__curtain');
    const captionEl = root.querySelector<HTMLElement>('[data-caption-text]');
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('.pc__dot'));
    if (slides.length === 0 || !curtain) return;

    const veil: HTMLElement = curtain;
    const imgs: HTMLImageElement[] = slides.map((s) => s.querySelector<HTMLImageElement>('img')!);
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let current = 0;
    let timer: number | undefined;
    let running = false;
    let swapTimer: number | undefined;

    function setActive(i: number): void {
      slides.forEach((s, k) => {
        const active = k === i;
        s.classList.toggle('is-active', active);
        s.setAttribute('aria-hidden', active ? 'false' : 'true');
        imgs[k].alt = active ? (s.dataset.alt ?? '') : '';
      });
      dots.forEach((d, k) => {
        d.classList.toggle('is-current', k === i);
        d.setAttribute('aria-current', k === i ? 'true' : 'false');
      });
      if (captionEl) captionEl.textContent = dots[i]?.dataset.caption ?? '';
    }

    function advance(): void {
      goTo((current + 1) % slides.length);
    }

    function goTo(next: number): void {
      if (next === current) return;
      window.clearTimeout(timer);
      window.clearTimeout(swapTimer);
      current = next;

      if (prefersReduced) {
        setActive(next);
        return;
      }

      // Retrigger the CSS curtain animation from its start.
      veil.classList.remove('is-wiping');
      // Force reflow so the browser restarts the animation on re-add.
      void veil.offsetWidth;
      veil.classList.add('is-wiping');

      // Swap the visible slide at the curtain's midpoint (fully covered).
      swapTimer = window.setTimeout(() => setActive(next), WIPE_MS / 2);
    }

    // When the curtain finishes wiping away, hold then advance.
    veil.addEventListener('animationend', () => {
      if (running) timer = window.setTimeout(advance, HOLD * 1000);
    });

    dots.forEach((d) => {
      d.addEventListener('click', () => {
        running = true;
        goTo(Number(d.dataset.index));
      });
    });

    if (prefersReduced) return;

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !running) {
          running = true;
          timer = window.setTimeout(advance, HOLD * 1000);
        } else if (!e.isIntersecting && running) {
          running = false;
          window.clearTimeout(timer);
        }
      });
    }, { threshold: 0.25 });
    io.observe(root);
  });
</script>

<style>
  .pc { margin: 0; }

  .pc__viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 2px;
    background: var(--rule);
  }

  /* Stacked slides — only the active one is visible. */
  .pc__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
  }
  .pc__slide.is-active {
    opacity: 1;
  }

  .pc__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform-origin: center center;
  }

  /* Ken Burns runs across each active slide's hold. */
  .pc__slide.is-active .pc__img {
    animation: pc-kenburns 4s linear forwards;
  }
  @keyframes pc-kenburns {
    from { transform: scale(1); }
    to   { transform: scale(1.03); }
  }

  /* Curtain: starts above the frame, wipes down to cover, continues down to leave. */
  .pc__curtain {
    position: absolute;
    inset: 0;
    background: var(--bg);
    transform: translateY(-100%);
    pointer-events: none;
    z-index: 2;
  }
  .pc__curtain.is-wiping {
    animation: pc-curtain 0.9s cubic-bezier(0.45, 0, 0.55, 1) forwards;
  }
  @keyframes pc-curtain {
    0%   { transform: translateY(-100%); }
    50%  { transform: translateY(0); }
    100% { transform: translateY(100%); }
  }

  .pc__dots {
    position: absolute;
    left: 0;
    right: 0;
    bottom: var(--space-3);
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    z-index: 3;
  }
  .pc__dot {
    width: 7px;
    height: 7px;
    padding: 0;
    border: 1px solid var(--accent);
    border-radius: 50%;
    background: transparent;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .pc__dot.is-current { background: var(--accent); }
  .pc__dot:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

  .pc__caption {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    opacity: 0.8;
    margin-top: var(--space-2);
  }
  .pc__caption:empty { display: none; }

  @media (prefers-reduced-motion: reduce) {
    .pc__curtain { display: none; }
    .pc__slide.is-active .pc__img { animation: none; }
    .pc__curtain.is-wiping { animation: none; }
  }
</style>
