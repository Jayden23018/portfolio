---
// Placed once on the home page as a quiet visual signature.
// Canvas 2D with IntersectionObserver lazy-init.
// prefers-reduced-motion / no-JS: static SVG fallback.
---

<div class="arc" data-arc-root aria-hidden="true">
  <!-- Lazy canvas (desktop + motion) -->
  <canvas class="arc__canvas" data-arc-canvas></canvas>

  <!-- Static SVG fallback (reduced-motion or no-JS) -->
  <svg
    class="arc__svg"
    viewBox="0 0 800 140"
    preserveAspectRatio="xMidYMid meet"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    focusable="false"
  >
    <!-- Three upward-curving arcs centered at (400, 320) -->
    <path d="M 88 140 A 320 320 0 0 1 712 140" fill="none" stroke="currentColor" stroke-width="1" opacity="0.10"/>
    <path d="M 28 140 A 380 380 0 0 1 772 140" fill="none" stroke="currentColor" stroke-width="1" opacity="0.13"/>
    <path d="M  0 108 A 440 440 0 0 1 800 108" fill="none" stroke="currentColor" stroke-width="1" opacity="0.08"/>
  </svg>
</div>

<script>
  (() => {
    const root   = document.querySelector('[data-arc-root]') as HTMLElement | null;
    const canvas = root?.querySelector('[data-arc-canvas]') as HTMLCanvasElement | null;
    if (!root || !canvas) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // On reduced-motion: hide canvas, show SVG — done via CSS
    if (prefersReduced) {
      root.dataset.arcStatic = '';
      return;
    }

    let rafId: number | null = null;
    let angle = 0;
    let ctx: CanvasRenderingContext2D | null = null;
    let W = 0, H = 140, cx = 0, cy = 0;
    const arcs = [
      { r: 0, w: 1.0, op: 0.10 },
      { r: 0, w: 1.0, op: 0.13 },
      { r: 0, w: 1.0, op: 0.08 },
    ];

    function setup() {
      ctx = canvas!.getContext('2d');
      if (!ctx) return false;
      const DPR = Math.min(window.devicePixelRatio ?? 1, 2);
      W = root!.clientWidth || 800;
      canvas!.width  = W * DPR;
      canvas!.height = H * DPR;
      canvas!.style.width  = `${W}px`;
      canvas!.style.height = `${H}px`;
      ctx.scale(DPR, DPR);
      cx = W / 2;
      cy = H + 180;
      arcs[0].r = W * 0.38;
      arcs[1].r = W * 0.48;
      arcs[2].r = W * 0.58;
      return true;
    }

    function draw() {
      if (!ctx) return;
      ctx.clearRect(0, 0, W, H);
      for (const arc of arcs) {
        const start = Math.PI + (Math.PI * 0.14) + angle;
        const end   = Math.PI * 2 - (Math.PI * 0.14) + angle;
        ctx.beginPath();
        ctx.arc(cx, cy, arc.r, start, end);
        ctx.strokeStyle = `rgba(33, 30, 24, ${arc.op})`;
        ctx.lineWidth   = arc.w;
        ctx.stroke();
      }
      angle += 0.00018;
      rafId = requestAnimationFrame(draw);
    }

    function init() {
      if (setup()) draw();
    }

    // Initialize once layout dimensions are available
    if (root!.clientWidth > 0) {
      init();
    } else {
      // Fallback: wait for load event when clientWidth isn't yet computed
      window.addEventListener('load', init, { once: true });
    }

    // Pause draw loop when ArcIndex scrolls fully off-screen
    const pauseObserver = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        if (!rafId) requestAnimationFrame(draw);
      } else {
        if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
      }
    }, { rootMargin: '100px' });
    pauseObserver.observe(root!);
  })();
</script>

<style>
  .arc {
    width: 100%;
    height: 140px;
    position: relative;
    overflow: hidden;
    color: var(--ink);
  }

  .arc__canvas {
    display: block;
    width: 100%;
    height: 140px;
  }

  .arc__svg {
    display: none;
    width: 100%;
    height: 140px;
  }

  /* Reduced-motion: hide canvas, show SVG */
  [data-arc-static] .arc__canvas { display: none; }
  [data-arc-static] .arc__svg    { display: block; }

  @media (prefers-reduced-motion: reduce) {
    .arc__canvas { display: none; }
    .arc__svg    { display: block; }
  }
</style>
