---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface PhotoItem {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

interface Props {
  images: PhotoItem[];
  id: string;
}

const { images, id } = Astro.props;
const total = images.length;
---

<dialog class="lb" id={`lb-${id}`} aria-label="Photo viewer">
  <div class="lb__content">

    <button class="lb__close" type="button" aria-label="Close photo viewer">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false"
           fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>

    <div class="lb__stage">
      <button class="lb__nav lb__nav--prev" type="button" aria-label="Previous photo">
        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" focusable="false"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>

      <div class="lb__slides">
        {images.map((img, idx) => (
          <figure class="lb__slide" data-slide={idx} hidden>
            <Image
              src={img.src}
              alt={img.alt}
              class="lb__img"
              widths={[900, 1400, 2000]}
              sizes="(max-width: 640px) 100vw, 90vw"
              loading="lazy"
            />
            {img.caption && <figcaption class="lb__caption">{img.caption}</figcaption>}
          </figure>
        ))}
      </div>

      <button class="lb__nav lb__nav--next" type="button" aria-label="Next photo">
        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" focusable="false"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    </div>

    <p class="lb__counter" aria-live="polite" aria-atomic="true"></p>

  </div>
</dialog>

<script define:vars={{ id, total }}>
  (() => {
    const dialog  = document.getElementById(`lb-${id}`);
    if (!dialog) return;

    const slides  = [...dialog.querySelectorAll('[data-slide]')];
    const counter = dialog.querySelector('.lb__counter');
    const prevBtn = dialog.querySelector('.lb__nav--prev');
    const nextBtn = dialog.querySelector('.lb__nav--next');
    const closeBtn = dialog.querySelector('.lb__close');
    const content  = dialog.querySelector('.lb__content');

    let current = 0;

    function show(idx) {
      const target = Math.max(0, Math.min(idx, total - 1));
      slides[current].hidden = true;
      slides[target].hidden  = false;
      current = target;
      if (counter) counter.textContent = total > 1 ? `${current + 1} / ${total}` : '';
      if (prevBtn) prevBtn.disabled = current === 0;
      if (nextBtn) nextBtn.disabled = current === total - 1;
    }

    // Triggered by PhotoGrid via custom event
    dialog.addEventListener('lb:open', (e) => {
      show(e.detail.idx);
      dialog.showModal();
    });

    closeBtn?.addEventListener('click', () => dialog.close());
    prevBtn?.addEventListener('click',  () => show(current - 1));
    nextBtn?.addEventListener('click',  () => show(current + 1));

    // Click outside .lb__content → close
    dialog.addEventListener('click', (e) => {
      if (content && !content.contains(e.target)) dialog.close();
    });

    // Arrow key navigation
    dialog.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft')  { e.preventDefault(); show(current - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); show(current + 1); }
    });

    // Hide nav when only one image
    if (total <= 1) {
      prevBtn?.setAttribute('hidden', '');
      nextBtn?.setAttribute('hidden', '');
    }
  })();
</script>

<style>
  .lb {
    position: fixed;
    inset: 0;
    width: 100vw;
    max-width: 100vw;
    height: 100dvh;
    max-height: 100dvh;
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    overflow: hidden;
  }

  .lb::backdrop {
    background: rgba(33, 30, 24, 0.92);
  }

  .lb__content {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
    gap: var(--space-4);
  }

  .lb__close {
    position: fixed;
    top: var(--space-6);
    right: var(--space-6);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid rgba(244, 240, 230, 0.25);
    color: var(--bg);
    cursor: pointer;
    border-radius: 2px;
    z-index: 10;
  }

  .lb__close:hover { background: rgba(244, 240, 230, 0.1); }
  .lb__close:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  .lb__stage {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    width: 100%;
    max-width: min(90vw, 1200px);
  }

  .lb__slides {
    flex: 1;
    min-width: 0;
  }

  .lb__slide {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0;
  }

  .lb__img {
    max-height: 80vh;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .lb__caption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    color: rgba(244, 240, 230, 0.6);
    margin-top: var(--space-3);
    text-align: center;
  }

  .lb__nav {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid rgba(244, 240, 230, 0.25);
    color: var(--bg);
    cursor: pointer;
    border-radius: 2px;
  }

  .lb__nav:disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }

  .lb__nav:not(:disabled):hover { background: rgba(244, 240, 230, 0.1); }
  .lb__nav:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  .lb__counter {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    color: rgba(244, 240, 230, 0.4);
    text-align: center;
    min-height: 1em;
  }

  /* No transform-based animations — fully prefers-reduced-motion safe by design */

  @media (max-width: 640px) {
    .lb__stage { gap: var(--space-2); }
    .lb__nav { width: 36px; height: 36px; }
    .lb__close { top: var(--space-4); right: var(--space-4); }
  }
</style>
