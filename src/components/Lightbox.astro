---
import { Image, getImage } from 'astro:assets';
import type { ExploreSeriesInput } from '../lib/explore-layout';

interface Props {
  series: ExploreSeriesInput[];
  id: string;
}

const { series, id } = Astro.props;
const sorted = [...series].sort((a, b) => a.order - b.order);

// Every photo across all series — stacked slides, toggled by global idx.
const allPhotos = sorted.flatMap((s) => s.photos);

// Every photo's thumbnail, flattened across all series (~200px webp).
const allThumbs = await Promise.all(
  allPhotos.map(async (p) => ({
    gidx: p.globalIdx,
    src:
      p.src.format === 'svg'
        ? p.src.src
        : (await getImage({ src: p.src, width: 200, format: 'webp' })).src,
    alt: p.alt,
  }))
);

// Compact seriesOf source handed to JS: [{ title, year, idx: [gidx…] }]
const seriesData = sorted.map((s) => ({
  title: s.title,
  year: s.photos[0]?.year ?? '',
  idx: s.photos.map((p) => p.globalIdx),
}));
---

<dialog class="lb" id={`lb-${id}`} aria-label="Photo viewer">
  <header class="lb__bar">
    <span class="lb__series" data-series-title></span>
    <span class="lb__count" data-count aria-live="polite" aria-atomic="true"></span>
    <button class="lb__close" type="button" aria-label="Close photo viewer">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false"
           fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M18 6 6 18M6 6l12 12" />
      </svg>
    </button>
  </header>

  <div class="lb__body">
    <div class="lb__stage">
      <div class="lb__slides">
        {allPhotos.map((p) => (
          <figure class="lb__slide" data-gidx={p.globalIdx} hidden>
            <Image
              src={p.src}
              alt={p.alt}
              class="lb__img"
              widths={[900, 1400, 2000]}
              sizes="(max-width: 768px) 100vw, 72vw"
              loading="lazy"
            />
            {p.caption && <figcaption class="lb__caption">{p.caption}</figcaption>}
          </figure>
        ))}
      </div>
      <div class="lb-curtain" aria-hidden="true"></div>
    </div>

    <aside class="lb__filmstrip" aria-label="All photos">
      <div class="lb__thumbs">
        {allThumbs.map((t) => (
          <button class="lb-thumb" type="button" data-gidx={t.gidx} aria-label={`View photo ${t.gidx}`}>
            <img src={t.src} alt="" class="lb-thumb__img" loading="lazy" />
          </button>
        ))}
      </div>
    </aside>
  </div>

  <script type="application/json" data-lb-data set:html={JSON.stringify(seriesData)}></script>
</dialog>

<script define:vars={{ id }}>
  (() => {
    const dialog = document.getElementById(`lb-${id}`);
    if (!dialog) return;

    const seriesData = JSON.parse(dialog.querySelector('[data-lb-data]')?.textContent || '[]');
    const seriesOf = new Map();
    seriesData.forEach((s) =>
      s.idx.forEach((gidx, i) =>
        seriesOf.set(gidx, { title: s.title, year: s.year, sidx: i, list: s.idx })
      )
    );

    const slides = [...dialog.querySelectorAll('.lb__slide')];
    const allGidxs = [...dialog.querySelectorAll('.lb-thumb')].map((t) => Number(t.dataset.gidx));
    const seriesEl = dialog.querySelector('[data-series-title]');
    const countEl = dialog.querySelector('[data-count]');
    const veil = dialog.querySelector('.lb-curtain');
    const closeBtn = dialog.querySelector('.lb__close');

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const WIPE_MS = 800;

    let curGidx = null;
    let swapTimer;
    let isAnimating = false;

    function setSlide(gidx) {
      const info = seriesOf.get(gidx); // bar title/year only
      slides.forEach((el) => { el.hidden = Number(el.dataset.gidx) !== gidx; });
      dialog.querySelectorAll('.lb-thumb').forEach((t) => {
        const on = Number(t.dataset.gidx) === gidx;
        t.classList.toggle('is-current', on);
        t.setAttribute('aria-current', on ? 'true' : 'false');
        if (on) t.scrollIntoView({ block: 'center' });
      });
      if (seriesEl) seriesEl.textContent = info ? (info.year ? `${info.title} · ${info.year}` : info.title) : '';
      const i = allGidxs.indexOf(gidx);
      if (countEl) countEl.textContent = i >= 0 ? `${i + 1} / ${allGidxs.length}` : '';
      curGidx = gidx;
    }

    function goTo(gidx) {
      if (gidx === curGidx || isAnimating) return;
      if (prefersReduced) { setSlide(gidx); return; }
      isAnimating = true;
      // Restart the CSS curtain animation (reflow resets the trigger).
      veil.classList.remove('is-wiping');
      void veil.offsetWidth;
      veil.classList.add('is-wiping');
      // Swap the photo at the curtain's midpoint (fully covered — no flash).
      window.clearTimeout(swapTimer);
      swapTimer = window.setTimeout(() => setSlide(gidx), WIPE_MS / 2);
    }

    function step(delta) {
      const i = allGidxs.indexOf(curGidx);
      if (i < 0) return;
      const len = allGidxs.length;
      const ni = (i + delta + len) % len; // loop across ALL photos
      goTo(allGidxs[ni]);
    }

    dialog.addEventListener('lb:open', (e) => {
      setSlide(e.detail.idx);
      dialog.showModal();
    });

    closeBtn?.addEventListener('click', () => dialog.close());

    dialog.addEventListener('click', (e) => {
      const thumb = e.target.closest('.lb-thumb');
      if (thumb) { goTo(Number(thumb.dataset.gidx)); return; }
      // Click the empty slide area or the dialog itself to close (not the image).
      if (e.target === dialog || (e.target.classList && e.target.classList.contains('lb__slide'))) {
        dialog.close();
      }
    });

    dialog.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft') { e.preventDefault(); step(-1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); step(1); }
    });

    veil?.addEventListener('animationend', () => { isAnimating = false; });
  })();
</script>

<style>
  .lb {
    position: fixed;
    inset: 0;
    width: 100vw;
    max-width: 100vw;
    height: 100dvh;
    max-height: 100dvh;
    background: var(--bg);
    border: none;
    padding: 0;
    margin: 0;
    overflow: hidden;
    color: var(--ink);
  }
  /* Only display when open — without this the author `display:flex` below
     would override the UA `[hidden]`/closed-dialog `display:none` and the
     dialog would show over the grid even when closed. */
  .lb[open] {
    display: flex;
    flex-direction: column;
  }
  .lb::backdrop {
    background: var(--bg);
  }

  /* ── Top bar ── */
  .lb__bar {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--rule);
    flex-shrink: 0;
    z-index: 20;
  }
  .lb__series {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--ink-2);
    flex: 1;
    min-width: 0;
  }
  .lb__count {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--ink-2);
  }
  .lb__close {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink);
    cursor: pointer;
    border-radius: 2px;
  }
  .lb__close:hover { background: var(--rule); }
  .lb__close:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  /* ── Body: stage + filmstrip ── */
  .lb__body {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: var(--space-6);
    padding: var(--space-6);
  }

  .lb__stage {
    position: relative;
    overflow: hidden;
    min-width: 0;
    border-radius: 2px;
  }
  .lb__slides {
    position: absolute;
    inset: 0;
  }
  .lb__slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    margin: 0;
    padding: var(--space-4);
  }
  .lb__img {
    max-width: 100%;
    max-height: calc(100dvh - 12rem);
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }
  .lb__caption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-2);
    text-align: center;
  }

  /* ── Curtain: bottom → cover (swap) → bottom, two-step ── */
  .lb-curtain {
    position: absolute;
    inset: 0;
    background: var(--bg);
    transform: translateY(100%);
    pointer-events: none;
    z-index: 10;
  }
  .lb-curtain.is-wiping {
    animation: lb-curtain 0.8s cubic-bezier(0.45, 0, 0.55, 1) forwards;
  }
  @keyframes lb-curtain {
    0%   { transform: translateY(100%); }
    50%  { transform: translateY(0); }
    100% { transform: translateY(100%); }
  }

  /* ── Filmstrip (right column) ── */
  .lb__filmstrip {
    overflow-y: auto;
    z-index: 20;
    display: flex;
    flex-direction: column;
  }
  .lb__group {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  /* The `hidden` attribute must win over the display:flex above, otherwise
     every slide/group renders stacked (photo never changes, filmstrip fixed). */
  .lb__slide[hidden],
  .lb__group[hidden] {
    display: none;
  }
  .lb__group-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--ink-2);
  }
  .lb__group-year { color: var(--rule); }

  .lb__thumbs {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .lb-thumb {
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: 2px;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    display: block;
  }
  .lb-thumb__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .lb-thumb.is-current {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .lb-thumb:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ── Reduced motion: drop the curtain, hard-cut ── */
  @media (prefers-reduced-motion: reduce) {
    .lb-curtain { display: none; }
    .lb-curtain.is-wiping { animation: none; }
  }

  /* ── Mobile: filmstrip collapses to a bottom row ── */
  @media (max-width: 768px) {
    .lb__body {
      grid-template-columns: 1fr;
      grid-template-rows: 1fr auto;
      gap: var(--space-3);
      padding: var(--space-4);
    }
    .lb__filmstrip {
      overflow-x: auto;
      overflow-y: hidden;
      max-height: 104px;
    }
    .lb__group-label { display: none; }
    .lb__thumbs {
      flex-direction: row;
      gap: var(--space-2);
    }
    .lb-thumb {
      width: 104px;
      flex-shrink: 0;
    }
    .lb__img {
      max-height: calc(100dvh - 19rem);
    }
  }
</style>
