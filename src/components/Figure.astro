---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Captioned figure for MDX project bodies. `span: 'full'` fills the column,
// `'half'` narrows it for smaller diagrams / inline pairings.
interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  span?: 'full' | 'half';
}

const { src, alt, caption, span = 'full' } = Astro.props;
const isSvg = src.format === 'svg';
---

<figure class:list={['figure', `figure--${span}`]}>
  {isSvg ? (
    <img src={src.src} alt={alt} class="figure__img" loading="lazy" decoding="async" />
  ) : (
    <Image
      src={src}
      alt={alt}
      class="figure__img"
      widths={[600, 900, 1400, 2000]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 90vw, 880px"
      loading="lazy"
    />
  )}
  {caption && <figcaption class="figure__caption">{caption}</figcaption>}
</figure>

<style>
  .figure {
    margin: var(--space-8) 0;
  }

  .figure__img {
    width: 100%;
    height: auto;
    border-radius: 2px;
    display: block;
    background: var(--bg-2);
  }

  .figure__caption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--ink-2);
    margin-top: var(--space-3);
    max-width: 70ch;
  }

  .figure--half {
    max-width: 60%;
  }
</style>
