---
interface Props {
  tags: string[];
}
const { tags } = Astro.props;
---

<ul class="tech-tags" role="list">
  {tags.map(tag => <li class="tech-tag">{tag}</li>)}
</ul>

<style>
  .tech-tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tech-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--ink-2);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.2em 0.6em;
    white-space: nowrap;
  }
</style>
